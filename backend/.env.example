# --- Flask Core ---
SECRET_KEY=generate_a_secure_random_key_here
FLASK_ENV=production
DEBUG=False
PORT=5000

# --- App Seeding ---
# Default superadmin password (only used on FIRST run if no superadmin exists)
SUPERADMIN_DEFAULT_PASSWORD=ChangeMe@123!

# --- Database ---
# Format: mysql+mysqlconnector://user:password@host:port/dbname
DATABASE_URL=mysql+mysqlconnector://user:password@host:3306/dbname

# --- CORS ---
# Comma-separated list of allowed origins (production frontend URL)
ALLOWED_ORIGINS=https://isms-frontend.onrender.com

# --- File Storage ---
SCREENSHOT_FOLDER=storage/screenshots

# --- JWT (if used) ---
JWT_SECRET_KEY=another_secure_random_key
JWT_ACCESS_TOKEN_EXPIRES=3600

# --- Razorpay ---
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

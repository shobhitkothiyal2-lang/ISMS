# ISMS Project .gitignore

# --- Node.js / Frontend ---
node_modules/
dist/
dist-ssr/
*.local
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Python / Backend ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv/
backend/database.db
backend/storage/screenshots/

# --- Environment Variables ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- IDE / Editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Testing ---
coverage/
.nyc_output/

# --- Misc ---
.cache/
.parcel-cache/
.temp/
